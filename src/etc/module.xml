<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Module/etc/module.xsd">
    <module name="MageObsidian_GiftMessage">
        <sequence>
            <!-- Inherits the legacy-layout neutralization and render_vue/Twig host. -->
            <module name="MageObsidian_Storefront"/>
            <module name="MageObsidian_ModernFrontend"/>
            <!-- Adds the gift-options editor onto the MageObsidian cart block. -->
            <module name="MageObsidian_Checkout"/>
            <!-- Displays the saved message on the order view documents. -->
            <module name="MageObsidian_Sales"/>
            <!-- Load after the core gift-message module whose frontend this adapts. -->
            <module name="Magento_GiftMessage"/>
        </sequence>
    </module>
</config>
